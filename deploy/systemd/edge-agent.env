# Edge-agent environment (installed to /etc/bwpool/edge-agent.env).
# All variables are namespaced with the BWPOOL_ prefix; see
# internal/config/config.go and internal/agent/config.go.

# Required: identifies which edge this agent is (no default).
BWPOOL_EDGE_ID=edge-1

# Optional overrides (defaults shown):
# BWPOOL_BIRD_SOCKET=/run/bird.ctl
# BWPOOL_VPP_API_SOCKET=/run/vpp/api.sock
# BWPOOL_RECONCILE_INTERVAL=60s
# BWPOOL_LOG_LEVEL=info
# BWPOOL_LOG_FORMAT=json
